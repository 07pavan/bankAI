# Firebase / Firestore Configuration
# You must provide either FIREBASE_CREDENTIALS_JSON (inline JSON string) or FIREBASE_CREDENTIALS_PATH (file path)
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption Configuration (use cryptography.fernet.Fernet.generate_key() to generate a key)
ENCRYPTION_KEY=your-base64-encryption-key-here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Application
APP_NAME=BankAI KYC API
APP_VERSION=2.0.0

# LLM Configuration (LangGraph + Groq/xAI)
# If LLM_API_KEY is not provided, the conversation agent falls back to the keyword-based agent automatically.
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your-groq-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
