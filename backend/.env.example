# Database Configuration
DATABASE_URL=postgresql://postgres:2004pavan@localhost:5432/bankai_db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption Configuration (use cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=your-base64-encryption-key-here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Application
APP_NAME=BankAI KYC API
APP_VERSION=2.0.0
