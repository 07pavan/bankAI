# Database Configuration
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/bankai_db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption Configuration (use cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=your-base64-encryption-key-here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Application
APP_NAME=BankAI KYC API
APP_VERSION=2.0.0

# LLM Configuration (LangGraph + Groq/xAI)
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your-groq-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
# Optional: separate DB for LangGraph checkpoints (defaults to DATABASE_URL)
LANGGRAPH_CHECKPOINT_DB=
